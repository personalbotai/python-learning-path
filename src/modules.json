        { "id": "func-scope", "title": "Variable Scope (Local, Global, nonlocal)", "type": "theory", "duration": "20 menit", "tags": ["functions", "scope"] },
        { "id": "func-lambda", "title": "Lambda Functions", "type": "exercise", "duration": "15 menit", "tags": ["functions", "lambda"] },
        { "id": "func-docstrings", "title": "Docstrings & Type Hints", "type": "theory", "duration": "20 menit", "tags": ["functions", "documentation"] },
